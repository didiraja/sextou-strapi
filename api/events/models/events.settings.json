{
  "kind": "collectionType",
  "collectionName": "EventsCollection",
  "info": {
    "name": "Event",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "default": "Nome do Evento",
      "required": true,
      "minLength": 10
    },
    "Date": {
      "type": "datetime",
      "required": true
    },
    "Description": {
      "type": "richtext",
      "default": "Digite aqui a descrição do seu evento. Aceita Rich Text,",
      "required": true
    },
    "Ticket": {
      "type": "string",
      "default": "Link de compra de ingressos do seu evento"
    },
    "Cover": {
      "model": "file",
      "via": "related",
      "allowedTypes": [
        "images"
      ],
      "plugin": "upload",
      "required": true,
      "pluginOptions": {}
    },
    "Zone": {
      "via": "Events",
      "model": "zone"
    },
    "Neighbor": {
      "model": "neighbor"
    }
  }
}
